# API Keys (Ollama needs a non-empty placeholder)
OPENAI_API_KEY="ollama"
ANTHROPIC_API_KEY=""

# Connection Settings - Force the redirect
OLLAMA="http://172.17.0.1:11434"
OPENAI_API_BASE="http://172.17.0.1:11434/v1"
OPENAI_BASE_URL="http://172.17.0.1:11434/v1"

# Model Identification
# The prefix 'ollama/' triggers the local provider logic in CAI
CAI_MODEL="ollama/DeepHat/DeepHat-V1-7B:latest"

# Framework Flags
PROMPT_TOOLKIT_NO_CPR=1
CAI_STREAM=false
CAI_DEBUG=0